@page "/index"
@{
    ViewData["Title"] = "Bienvenida";
}

<div class="card-panel bienvenida">
    <div class="bienvenida-logo"><i class="bi bi-person-badge"></i></div>
    <h1 class="bienvenida-titulo">Bienvenido, <span id="bienvenidaNombre">Usuario</span></h1>
    <p class="bienvenida-sub">Carnet Digital &middot; Colegio Universitario de Cartago</p>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var nombre = localStorage.getItem('nombreCompleto');
        document.getElementById('bienvenidaNombre').textContent = nombre || 'Usuario';
    });
</script>

<style>
    .bienvenida {
        max-width: 560px;
        margin: 40px auto 0;
        text-align: center;
        padding: 48px 32px;
    }

    .bienvenida-logo {
        width: 88px;
        height: 88px;
        margin: 0 auto 22px;
        border-radius: 50%;
        background: var(--azul);
        color: #ffd700;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
    }

    .bienvenida-titulo {
        font-size: 1.6rem;
        font-weight: 600;
        color: var(--azul);
        margin-bottom: 8px;
    }

    .bienvenida-sub {
        color: #6c757d;
        font-size: .95rem;
        margin: 0;
    }
</style>
