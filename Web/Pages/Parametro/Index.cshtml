@page
@model CarnetDigitalWeb.Pages.Parametro.IndexModel
@{
    ViewData["Title"] = "Parámetros";
}

<div class="card-panel">
    <div class="toolbar">
        <span class="panel-eyebrow">SRV15 - Parametro</span>
        <a class="btn btn-cuc btn-sm" asp-page="Form">
            <i class="bi bi-plus-lg"></i> Nuevo
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle tabla-cuc">
            <thead>
                <tr>
                    <th style="width:170px">Código</th>
                    <th>Valor</th>
                    <th style="width:110px" class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Items)
                {
                    <tr>
                        <td><span class="clave">@p.Id</span></td>
                        <td class="valor-celda">@p.Valor</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary" asp-page="Form" asp-route-id="@p.Id">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" asp-page-handler="Eliminar" asp-route-id="@p.Id" class="d-inline"
                                  onsubmit="return confirm('¿Realmente desea eliminar el elemento seleccionado?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPaginas > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm mb-0">
                @for (var i = 1; i <= Model.TotalPaginas; i++)
                {
                    <li class="page-item @(i == Model.Pagina ? "active" : "")">
                        <a class="page-link" asp-page="Index" asp-route-pagina="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
