@page
@model CarnetDigitalWeb.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Iniciar Sesión";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Carnet Digital CUC</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">
    <style>
            body {
                background: linear-gradient(135deg, #1b2a4a 0%, #24365f 50%, #2a4a7a 100%);
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                margin: 0;
                padding: 20px;
            }

            .login-card {
                max-width: 420px;
                width: 100%;
                background: white;
                border-radius: 16px;
                padding: 40px;
                box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            }

            .login-logo {
                width: 80px;
                height: 80px;
                background: #1b2a4a;
                color: #ffd700;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 32px;
                font-weight: bold;
                margin: 0 auto 15px;
            }

            .login-title {
                color: #1b2a4a;
                font-size: 24px;
                font-weight: 600;
                text-align: center;
            }

            .login-subtitle {
                color: #6c757d;
                font-size: 14px;
                text-align: center;
                margin-bottom: 30px;
            }

            .alert {
                margin-bottom: 20px;
            }

            .btn-login {
                width: 100%;
                padding: 12px;
                background: #1b2a4a;
                color: white;
                border: none;
                border-radius: 8px;
                font-size: 16px;
                font-weight: 600;
                cursor: pointer;
                transition: all 0.3s ease;
            }

                .btn-login:hover {
                    background: #0f1a30;
                }

                .btn-login:disabled {
                    opacity: 0.7;
                    cursor: not-allowed;
                }

            .spinner-border-sm {
                width: 1rem;
                height: 1rem;
                border-width: 0.2em;
            }

            .login-footer {
                text-align: center;
                margin-top: 20px;
                color: #6c757d;
                font-size: 13px;
            }

            .login-registro {
                text-align: center;
                margin-top: 18px;
            }

            .link-registro {
                color: #8a94a6;
                font-size: 13px;
                text-decoration: none;
                cursor: not-allowed;
                border-bottom: 1px dashed #c7ccd6;
                padding-bottom: 1px;
            }

                .link-registro:hover {
                    color: #6c757d;
                }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-logo">CUC</div>
        <h1 class="login-title">Carnet Digital</h1>
        <p class="login-subtitle">Inicia sesión para acceder al sistema</p>

        <div id="alertMessage" class="alert" style="display:none;"></div>

        <form id="loginForm" onsubmit="return handleLogin(event)">
            <div class="mb-3">
                <label class="form-label">Correo Electrónico</label>
                <input type="email" id="email" class="form-control" placeholder="ejemplo@cuc.ac.cr" value="prueba@cuc.ac.cr">
                <div class="invalid-feedback" id="emailError"></div>
            </div>

            <div class="mb-3">
                <label class="form-label">Contraseña</label>
                <input type="password" id="password" class="form-control" placeholder="Ingrese su contraseña" value="Prueba1234">
                <div class="invalid-feedback" id="passwordError"></div>
            </div>

            <div class="mb-3">
                <label class="form-label">Tipo de Usuario</label>
                <select id="tipoUsuario" class="form-select">
                    <option value="">Seleccione un tipo...</option>
                    <option value="Administrador" selected>Administrador</option>
                    <option value="Funcionario">Funcionario</option>
                    <option value="Estudiante">Estudiante</option>
                </select>
                <div class="invalid-feedback" id="tipoUsuarioError"></div>
            </div>

            <button type="submit" class="btn-login" id="btnLogin">
                <span id="btnText">Iniciar Sesión</span>
                <span id="btnSpinner" style="display:none;">
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    Cargando...
                </span>
            </button>
        </form>

        <div class="login-registro">
            <a href="#" class="link-registro" title="Próximamente" onclick="return false;">
                ¿No tiene cuenta? Regístrese aquí
            </a>
        </div>

        <div class="login-footer">
            <p>Sistema de Carnet Digital - CUC</p>
        </div>
    </div>

    <script>
            // ========================================
            // 🔐 FUNCIONES PARA OBTENER TOKEN
            // ========================================

            function getToken() {
                return localStorage.getItem('accessToken');
            }

            function getHeaders() {
                const token = getToken();
                if (!token) {
                    mostrarAlerta('No hay sesión activa. Redirigiendo...', 'warning');
                    setTimeout(function() {
                        window.location.href = '/Login';
                    }, 1500);
                    return null;
                }
                return {
                    'Authorization': 'Bearer ' + token,
                    'Content-Type': 'application/json'
                };
            }

            function mostrarAlerta(mensaje, tipo) {
                var alertDiv = document.getElementById('alertMessage');
                alertDiv.textContent = mensaje;
                alertDiv.className = 'alert alert-' + tipo;
                alertDiv.style.display = 'block';
            }

            function limpiarErrores() {
                document.querySelectorAll('.is-invalid').forEach(function(el) {
                    el.classList.remove('is-invalid');
                });
                document.querySelectorAll('.invalid-feedback').forEach(function(el) {
                    el.textContent = '';
                });
            }

            function mostrarError(campo, mensaje) {
                var el = document.getElementById(campo);
                var errorEl = document.getElementById(campo + 'Error');
                el.classList.add('is-invalid');
                errorEl.textContent = mensaje;
            }

            function validarFormulario() {
                var valido = true;
                limpiarErrores();

                var email = document.getElementById('email').value.trim();
                var password = document.getElementById('password').value.trim();
                var tipoUsuario = document.getElementById('tipoUsuario').value;

                if (!email) {
                    mostrarError('email', 'El correo electrónico es requerido');
                    valido = false;
                } else if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
                    mostrarError('email', 'Ingrese un correo electrónico válido');
                    valido = false;
                }

                if (!password) {
                    mostrarError('password', 'La contraseña es requerida');
                    valido = false;
                } else if (password.length < 6) {
                    mostrarError('password', 'La contraseña debe tener al menos 6 caracteres');
                    valido = false;
                }

                if (!tipoUsuario) {
                    mostrarError('tipoUsuario', 'Seleccione un tipo de usuario');
                    valido = false;
                }

                return valido;
            }

            async function handleLogin(event) {
                event.preventDefault();

                if (!validarFormulario()) {
                    return false;
                }

                var btnLogin = document.getElementById('btnLogin');
                var btnText = document.getElementById('btnText');
                var btnSpinner = document.getElementById('btnSpinner');

                btnLogin.disabled = true;
                btnText.style.display = 'none';
                btnSpinner.style.display = 'inline-block';

                var email = document.getElementById('email').value.trim();
                var password = document.getElementById('password').value.trim();
                var tipoUsuario = document.getElementById('tipoUsuario').value;

                try {
                    var response = await fetch('/api/login', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            email: email,
                            password: password,
                            tipo: tipoUsuario
                        })
                    });

                    var data = await response.json();

                    if (data.success) {
                        localStorage.setItem('accessToken', data.accessToken);
                        localStorage.setItem('refreshToken', data.refreshToken);
                        localStorage.setItem('tokenType', data.tokenType || 'Bearer');
                        localStorage.setItem('expiresIn', data.expiresIn || 3600);

                        if (data.user) {
                            localStorage.setItem('usuarioId', data.user.id);
                            localStorage.setItem('usuarioEmail', data.user.email);
                            localStorage.setItem('nombreCompleto', data.user.nombreCompleto);
                            localStorage.setItem('usuarioTipo', data.user.tipoUsuario);
                            localStorage.setItem('usuarioTipoId', data.user.tipoUsuarioId || '');
                        }

                        mostrarAlerta('¡Login exitoso! Redirigiendo...', 'success');

                        setTimeout(function() {
                            window.location.href = '/index';
                        }, 1000);
                    } else {
                        mostrarAlerta(data.message || 'Credenciales inválidas', 'danger');
                    }
                } catch (error) {
                    mostrarAlerta('Error de conexión: ' + error.message, 'danger');
                } finally {
                    btnLogin.disabled = false;
                    btnText.style.display = 'inline';
                    btnSpinner.style.display = 'none';
                }

                return false;
            }
    </script>
</body>
</html>